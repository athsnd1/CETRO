    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#TrafficCondition -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#TrafficCondition"/>
    


    <!-- http://www.uniuyo.edu.ng/cetro#TransportMode -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    


