    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#RailMode -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#RailMode">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#RainyWeather -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#RainyWeather">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#WeatherCondition"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Route -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Route"/>
    


    <!-- http://www.uniuyo.edu.ng/cetro#ShortestRoute -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#ShortestRoute">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.uniuyo.edu.ng/cetro#Route"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.uniuyo.edu.ng/cetro#hasDistance"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">300</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#StableFlow -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#StableFlow">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TrafficCondition"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#SunnyWeather -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#SunnyWeather">
