    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.uniuyo.edu.ng/cetro#AKTC -->

    <owl:NamedIndividual rdf:about="http://www.uniuyo.edu.ng/cetro#AKTC">
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#PublicTransportService"/>
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportationService"/>
    </owl:NamedIndividual>
    


    <!-- http://www.uniuyo.edu.ng/cetro#AKTC_Bus_1 -->

    <owl:NamedIndividual rdf:about="http://www.uniuyo.edu.ng/cetro#AKTC_Bus_1">
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#Bus"/>
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <cetro:belongsTo rdf:resource="http://www.uniuyo.edu.ng/cetro#Uwem"/>
        <cetro:fuelUsed rdf:datatype="http://www.w3.org/2001/XMLSchema#float">45.0</cetro:fuelUsed>
        <cetro:hasMake>Innoson</cetro:hasMake>
        <cetro:hasModel>BRT</cetro:hasModel>
        <cetro:hasSpeed rdf:datatype="http://www.w3.org/2001/XMLSchema#float">30.4</cetro:hasSpeed>
    </owl:NamedIndividual>
    


    <!-- http://www.uniuyo.edu.ng/cetro#AKTC_Bus_2 -->

    <owl:NamedIndividual rdf:about="http://www.uniuyo.edu.ng/cetro#AKTC_Bus_2">
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#Bus"/>
        <rdf:type rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <cetro:belongsTo rdf:resource="http://www.uniuyo.edu.ng/cetro#Uwem"/>
        <cetro:fuelUsed rdf:datatype="http://www.w3.org/2001/XMLSchema#float">45.0</cetro:fuelUsed>
