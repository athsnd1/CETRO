<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uniuyo.edu.ng/cetro/"
     xml:base="http://www.uniuyo.edu.ng/cetro/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:cetro="http://www.uniuyo.edu.ng/cetro#">
    <owl:Ontology rdf:about="http://www.uniuyo.edu.ng/cetro"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.uniuyo.edu.ng/cetro#affectsRoute -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#affectsRoute">
        <owl:inverseOf rdf:resource="http://www.uniuyo.edu.ng/cetro#hasWeatherCondition"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#WeatherCondition"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#belongsTo -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#belongsTo">
        <owl:inverseOf rdf:resource="http://www.uniuyo.edu.ng/cetro#hasVehicle"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#endsAt -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#endsAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasMode -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasMode">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasTrafficCondition -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasTrafficCondition">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#TrafficCondition"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasVehicle -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasVehicle">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasWeatherCondition -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasWeatherCondition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#WeatherCondition"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#occursAt -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#occursAt">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#WeatherCondition"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#providedBy -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#providedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportationService"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#startsAt -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#startsAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#traversesRoute -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#traversesRoute">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#usesMode -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#usesMode">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    </owl:ObjectProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#usesRoute -->

    <owl:ObjectProperty rdf:about="http://www.uniuyo.edu.ng/cetro#usesRoute">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
        <rdfs:range rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.uniuyo.edu.ng/cetro#fuelUsed -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#fuelUsed">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasAvgCost -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasAvgCost">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasAvgDistance -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasAvgDistance">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasCost -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasCost">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasDistance -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasDistance">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasMake -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasMake">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasModel -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasModel">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasName">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasSpeed -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasSpeed">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.uniuyo.edu.ng/cetro#hasTravelTime -->

    <owl:DatatypeProperty rdf:about="http://www.uniuyo.edu.ng/cetro#hasTravelTime">
        <rdfs:domain rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.uniuyo.edu.ng/cetro#AirMode -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#AirMode">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Bike -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Bike">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#BikeOwner -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#BikeOwner">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Bus -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Bus">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#BusOwner -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#BusOwner">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#BusStop -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#BusStop">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Car -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Car">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Vehicle"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#CarOwner -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#CarOwner">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#User"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#CheapestRoute -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#CheapestRoute">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.uniuyo.edu.ng/cetro#Route"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.uniuyo.edu.ng/cetro#hasCost"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">200</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#City -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#City">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Congested -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Congested">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TrafficCondition"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#FloodedCondition -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#FloodedCondition">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#WeatherCondition"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#FreeFlow -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#FreeFlow">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TrafficCondition"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Junction -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Junction">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Location"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#LandMode -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#LandMode">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportMode"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#Location -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#Location"/>
    


    <!-- http://www.uniuyo.edu.ng/cetro#LongestRoute -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#LongestRoute">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.uniuyo.edu.ng/cetro#Route"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.uniuyo.edu.ng/cetro#hasDistance"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1000</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#Route"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#PrivateTransportService -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#PrivateTransportService">
        <rdfs:subClassOf rdf:resource="http://www.uniuyo.edu.ng/cetro#TransportationService"/>
    </owl:Class>
    


    <!-- http://www.uniuyo.edu.ng/cetro#PublicTransportService -->

    <owl:Class rdf:about="http://www.uniuyo.edu.ng/cetro#PublicTransportService">
